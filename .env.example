# =====================================================
#  WENEX — Variables de entorno
#  Copia este archivo como .env.local para desarrollo
#  En Vercel se configuran en Settings > Environment Variables
# =====================================================

# Base de datos PostgreSQL (Neon te dará esta URL al crear el proyecto)
DATABASE_URL="postgresql://user:password@host.neon.tech/wenex?sslmode=require"

# Auth (NextAuth)
# Genera un secret con: openssl rand -base64 32
NEXTAUTH_SECRET="cambia-esto-por-un-secret-de-32-bytes-aleatorios"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (opcional — login con Google)
# Crea credenciales en https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
